# Obsidian vault 절대 경로
VAULT_PATH=/Users/you/Documents

# 인덱싱 glob (vault 내 md 경로)
INDEX_INCLUDE=notion/**/*.md

# vault 내 RAG 인덱스 폴더
RAG_INDEX_DIR=.company-rag

# Cursor SDK — 웹 채팅 (https://cursor.com/settings)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# RAG top-k
RAG_TOP_K=5

# Qdrant (docker compose up -d)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=company-rag
