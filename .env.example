# Obsidian vault 또는 Git 레포 경로 (절대 경로)
VAULT_PATH=/path/to/your/vault

# Cursor SDK — https://cursor.com/settings
CURSOR_API_KEY=

# Cursor model id (예: composer-2.5)
CURSOR_MODEL=composer-2.5

# RAG top-k 검색 개수
RAG_TOP_K=5

# 임베딩: local | openai (MVP 기본: local)
EMBEDDING_MODEL=local

# 인덱싱 glob (MVP: markdown만)
INDEX_INCLUDE=**/*.md
