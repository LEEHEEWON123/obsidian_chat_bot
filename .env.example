# Obsidian vault 절대 경로
VAULT_PATH=/Users/you/Documents

# Obsidian vault 절대 경로
VAULT_PATH=/Users/you/Documents

# Notion → Obsidian export (npm run notion:export)
# 저장 경로: {VAULT_PATH}/{NOTION_EXPORT_DIR}/  예) ~/Documents/notion/
# NOTION_API_KEY=ntn_...
# NOTION_EXPORT_ROOT=https://app.notion.com/p/{page-id}
# NOTION_EXPORT_DIR=notion
# NOTION_MAX_PAGES=500

# Cursor SDK — https://cursor.com/settings
CURSOR_API_KEY=

# Cursor model id (예: composer-2.5)
CURSOR_MODEL=composer-2.5

# RAG top-k 검색 개수
RAG_TOP_K=5

# 임베딩: local | openai (MVP 기본: local)
EMBEDDING_MODEL=local

# 인덱싱 glob (MVP: markdown만)
INDEX_INCLUDE=**/*.md
