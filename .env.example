# Obsidian vault 절대 경로 (dobedub only)
VAULT_PATH=/Users/you/Documents/dobedub

# 인덱싱 glob (vault 내 md 경로)
INDEX_INCLUDE=**/*.md

# vault 내 RAG 인덱스 폴더
RAG_INDEX_DIR=.company-rag

# Cursor SDK — 웹 채팅 (https://cursor.com/settings)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Hermes MCP + Workspace UI (npm run hermes:setup / workspace:setup)
# HERMES_API_KEY=   # same as ~/.hermes/.env API_SERVER_KEY (workspace-setup reads this)
# Web UI: npm run workspace:dev → http://localhost:3000
# Legacy Next RAG UI: npm run dev → http://localhost:3001
# MCP_READ_NOTE_MAX_CHARS=80000

# RAG top-k (final results after rerank)
RAG_TOP_K=5

# Hybrid 1st-stage candidate pool size (before rerank)
RAG_RECALL_K=50

# Cross-encoder rerank (BAAI/bge-reranker-v2-m3 ONNX)
# Local CPU ~45s/query — default false for speed. true = higher precision, much slower.
RERANK_ENABLED=false
RERANK_MODEL=woxpas-ai/bge-reranker-v2-m3-onnx
RERANK_BATCH_SIZE=8
# Relevance floor (raw logit). Chunks scoring below this are dropped so
# irrelevant matches are not surfaced. 0 = balanced (sigmoid 0.5),
# lower (e.g. -2) = more lenient/higher recall.
RERANK_MIN_SCORE=0

# Hyperlink context: 1-hop graph expand (notion_link / wikilink)
GRAPH_EXPAND_HOPS=1
NOTE_CONTEXT_MAX_PATHS=10

# Embedding (re-index required after model/dimension change)
EMBEDDING_MODEL=Xenova/bge-m3
# EMBED_BATCH_SIZE=8

# Qdrant (docker compose up -d)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=company-rag

# NAVER Works DM share (MCP prepare_share → confirm_share_draft)
# Developer Console: https://developers.worksmobile.com/
# Scopes: bot, bot.message, bot.read, directory.read
# People directory (aliases → Works userId):
#   npm run works:sync-people   # directory.read로 멤버 pull → config/share-people.json
#   # 또는: cp config/share-people.example.json config/share-people.json
# SHARE_PEOPLE_FILE=config/share-people.json
# Group rooms (bot must be in the room; no list-all API):
#   npm run works:sync-room -- <channelId>   # → config/share-rooms.json
#   # 또는: cp config/share-rooms.example.json config/share-rooms.json
# SHARE_ROOMS_FILE=config/share-rooms.json
# SHARE_DRAFT_TTL_MS=1800000
# SHARE_LOG_FILE=data/share-log.jsonl   # confirm_share_draft audit log (under /data/)
# NAVER_WORKS_CLIENT_ID=
# NAVER_WORKS_CLIENT_SECRET=
# NAVER_WORKS_SERVICE_ACCOUNT=xxx@example.com
# NAVER_WORKS_BOT_ID=2000001
# Private key: path OR PEM with \n escapes
# NAVER_WORKS_PRIVATE_KEY_PATH=/absolute/path/to/private_202xxx.key
# NAVER_WORKS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# NAVER_WORKS_SCOPE=bot bot.message bot.read directory.read
# Mail (User OAuth — not Service Account):
# NAVER_WORKS_USER_OAUTH_SCOPE=mail.read user.read
# NAVER_WORKS_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/callback
# NAVER_WORKS_USER_REFRESH_TOKEN=   # npm run works:mail-auth
# NAVER_WORKS_MAIL_USER=ykjung@dobedub.com

# Notion → vault export (npm run notion:export)
NOTION_API_KEY=
NOTION_EXPORT_ROOT=https://app.notion.com/p/your-root-page-id
NOTION_EXPORT_DIR=dobedub/notion
# Nested child_page / link_to_page / <page url> follow; raise if truncated
NOTION_MAX_PAGES=2000

# PDF → sidecar markdown for RAG (npm run pdf:export, requires Java 11+)
# JAVA_HOME=/opt/homebrew/opt/openjdk@21
PDF_INCLUDE=**/*.pdf
PDF_INDEX_DIR=.pdf-index
# Auto-append .pdf-index/**/*.md to INDEX_INCLUDE unless PDF_INDEX_ENABLED=false
# PDF_INDEX_ENABLED=true
# Scanned PDFs: npm run pdf:hybrid:up (Docker, :5002)
PDF_HYBRID=docling-fast
PDF_HYBRID_URL=http://127.0.0.1:5002
PDF_HYBRID_MODE=full

# DOCX → sidecar markdown for RAG (npm run docx:export)
# Requires: pip3 install -r requirements-docx.txt
DOCX_INCLUDE=**/*.docx
DOCX_INDEX_DIR=.docx-index
# Auto-append .docx-index/**/*.md to INDEX_INCLUDE unless DOCX_INDEX_ENABLED=false
# DOCX_INDEX_ENABLED=true
# Optional: MARKITDOWN_PYTHON=/path/to/python3

# AX interview case — CSV joins + CLIP image search (MCP ax_asset_query / ax_image_search)
# pip3 install -r requirements-ax-clip.txt
# AX_CASE_DIR=/Users/you/Downloads/ax_pre_interview_case_exercise
# AX_CLIP_INDEX=data/ax-clip-index.json
# AX_CLIP_IMAGE_MODEL=sentence-transformers/clip-ViT-B-32
# AX_CLIP_TEXT_MODEL=sentence-transformers/clip-ViT-B-32-multilingual-v1
# AX_PYTHON=python3
# npm run ax:clip-index
# npm run ax:smoke
